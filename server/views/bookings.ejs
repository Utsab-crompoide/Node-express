<%- include('partials/header.ejs') %>

<link rel="stylesheet" href="/css/bookings.css"/>

<main class="pt-24 pb-24 md:pb-12 px-6 max-w-7xl mx-auto">
    <% const bookingsData = typeof bookingsPageData !== 'undefined' ? bookingsPageData : { title: 'My Bookings', subtitle: '', bookings: [] }; %>
    <% const bookings = bookingsData.bookings || []; %>

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-extrabold font-headline text-on-surface tracking-tight mb-2"><%= bookingsData.title %></h1>
        <p class="text-on-surface-variant text-sm md:text-base"><%= bookingsData.subtitle %></p>
    </div>

    <!-- Filters & Search Section -->
    <div class="bg-surface-container-low rounded-xl p-4 md:p-6 mb-8 space-y-4">
        <div class="flex flex-col gap-4 mb-4">
            <!-- Status Filter Chips -->
            <div class="flex items-center gap-2 flex-wrap">
                <button class="px-3 md:px-4 py-2 bg-primary text-on-primary font-medium text-xs md:text-sm rounded-full hover:opacity-90 transition-opacity" onclick="filterBookings('all')">
                    All
                </button>
                <button class="px-3 md:px-4 py-2 bg-surface text-on-surface font-medium text-xs md:text-sm rounded-full hover:bg-surface-container-high transition-colors" onclick="filterBookings('upcoming')">
                    Upcoming
                </button>
                <button class="px-3 md:px-4 py-2 bg-surface text-on-surface font-medium text-xs md:text-sm rounded-full hover:bg-surface-container-high transition-colors" onclick="filterBookings('completed')">
                    Completed
                </button>
            </div>

            <!-- Date Range Dropdown -->
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-on-surface-variant flex-shrink-0">calendar_month</span>
                <select class="flex-1 md:flex-none bg-surface text-on-surface text-xs md:text-sm font-medium border border-outline-variant rounded-lg px-3 py-2 cursor-pointer focus:outline-none focus:border-primary pr-8" onchange="filterByDateRange(this.value)">
                    <option value="all">Date Range</option>
                    <option value="week">This Week</option>
                    <option value="month">This Month</option>
                    <option value="quarter">This Quarter</option>
                </select>
            </div>
        </div>

        <!-- Search Venues -->
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant flex-shrink-0">search</span>
            <input 
                type="text" 
                placeholder="Search venues..." 
                class="w-full bg-surface text-on-surface text-xs md:text-sm placeholder-on-surface-variant pl-10 pr-4 py-2 rounded-lg border border-outline-variant focus:outline-none focus:border-primary transition-colors"
                onkeyup="searchVenues(this.value)"
            />
        </div>
    </div>

    <!-- Bookings List -->
    <div class="space-y-4" id="bookingsList">
        <% bookings.forEach((booking) => { %>
            <%- include('components/booking_card_horizontal', { booking }) %>
        <% }); %>
    </div>

    <!-- Load Older Bookings Button -->
    <div class="flex justify-center mt-8">
        <button class="px-6 md:px-8 py-2 bg-surface-container-low text-on-surface font-medium text-sm rounded-lg hover:bg-surface-container transition-colors" onclick="loadOlderBookings()">
            Load Older Bookings
        </button>
    </div>

    <!-- Floating Action Button -->
    <button class="fixed bottom-20 md:bottom-8 right-6 md:right-8 w-14 h-14 md:w-16 md:h-16 bg-primary hover:bg-primary-container text-on-primary rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 z-40">
        <span class="material-symbols-outlined text-xl md:text-2xl">add</span>
    </button>
</main>

