    function filterByDateRange(range) {
        console.log('Filter by date range:', range);
        // API call will be implemented here
    }

    function searchVenues(query) {
        console.log('Search venues:', query);
        // API call will be implemented here
    }

    function loadOlderBookings() {
        console.log('Load older bookings');
        // API call will be implemented here
    }
</script>
