<div class="flex gap-4 p-4 bg-surface-container-lowest rounded-lg <%= reminder.type === 'schedule' ? 'border-l-4 border-primary' : '' %>">
    <div class="w-10 h-10 flex items-center justify-center <%= reminder.type === 'schedule' ? 'bg-primary-fixed text-on-primary-fixed' : 'bg-secondary-fixed text-on-secondary-fixed' %> rounded-full shrink-0">
        <span class="material-symbols-outlined text-sm" data-icon="<%= reminder.icon %>"><%= reminder.icon %></span>
    </div>
    <div>
        <p class="text-sm font-bold text-on-surface"><%= reminder.title %></p>
        <p class="text-xs text-on-surface-variant"><%= reminder.description %></p>
    </div>
</div>
