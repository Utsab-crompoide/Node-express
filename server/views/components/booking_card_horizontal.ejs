<div class="bg-surface-container-lowest rounded-xl p-4 md:p-6 flex flex-col md:flex-row md:items-center gap-4 md:gap-6 border-l-4 border-primary hover:shadow-md transition-all duration-300">
    <!-- Venue Image -->
    <div class="flex-shrink-0">
        <div class="w-full md:w-20 h-40 md:h-20 rounded-lg overflow-hidden bg-surface-container">
            <img 
                src="<%= booking.venueImage %>" 
                alt="<%= booking.venueName %>" 
                class="w-full h-full object-cover"
            />
        </div>
    </div>

    <!-- Booking Details -->
    <div class="flex-1 min-w-0">
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-3">
            <h3 class="text-lg font-bold font-headline text-on-surface truncate"><%= booking.venueName %></h3>
            <% if (booking.status === 'UPCOMING') { %>
                <span class="px-3 py-1 bg-secondary-container text-on-secondary-container text-[10px] font-bold uppercase tracking-wider rounded-full w-fit">
                    <%= booking.status %>
                </span>
            <% } else if (booking.status === 'COMPLETED') { %>
                <span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed text-[10px] font-bold uppercase tracking-wider rounded-full w-fit">
                    <%= booking.status %>
                </span>
            <% } else if (booking.status === 'CANCELLED') { %>
                <span class="px-3 py-1 bg-error-container text-on-error-container text-[10px] font-bold uppercase tracking-wider rounded-full w-fit">
                    <%= booking.status %>
                </span>
            <% } %>
        </div>

        <!-- Date, Time, Location -->
        <div class="flex flex-col sm:flex-row sm:flex-wrap items-start sm:items-center gap-2 sm:gap-4 text-on-surface-variant text-sm">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base flex-shrink-0">calendar_today</span>
                <span><%= booking.date %></span>
            </div>
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base flex-shrink-0">schedule</span>
                <span><%= booking.startTime %> - <%= booking.endTime %></span>
            </div>
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-base flex-shrink-0">location_on</span>
                <span><%= booking.location %></span>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="w-full md:w-auto flex flex-col sm:flex-row gap-2 md:gap-3 md:flex-shrink-0 md:ml-auto">
        <% if (booking.status === 'UPCOMING') { %>
            <button class="px-3 md:px-4 py-2 text-on-surface font-medium text-sm hover:bg-surface-container-low rounded-lg transition-colors whitespace-nowrap">
                View Details
            </button>
            <button class="px-4 md:px-6 py-2 bg-primary text-on-primary font-medium text-sm rounded-lg hover:bg-primary-container transition-colors whitespace-nowrap">
                Cancel Booking
            </button>
        <% } else if (booking.status === 'COMPLETED') { %>
            <button class="px-3 md:px-4 py-2 text-on-surface font-medium text-sm hover:bg-surface-container-low rounded-lg transition-colors whitespace-nowrap">
                View Details
            </button>
            <button class="px-4 md:px-6 py-2 border border-primary text-primary font-medium text-sm rounded-lg hover:bg-primary-fixed transition-colors whitespace-nowrap">
                Book Again
            </button>
        <% } else if (booking.status === 'CANCELLED') { %>
            <button class="px-3 md:px-4 py-2 text-on-surface font-medium text-sm hover:bg-surface-container-low rounded-lg transition-colors whitespace-nowrap">
                View Receipt
            </button>
            <button class="px-4 md:px-6 py-2 bg-surface-container text-on-surface font-medium text-sm rounded-lg cursor-default whitespace-nowrap">
                Refunded
            </button>
        <% } %>
    </div>
</div>
