<%- include('partials/header.ejs') %>

    <main class="pt-24 pb-12 px-6 max-w-7xl mx-auto">
        <% const exploreData = typeof explorePageData !== 'undefined' ? explorePageData : { sidebar: {}, listing: {} }; %>
        <% const sidebar = exploreData.sidebar || {}; %>
        <% const listing = exploreData.listing || {}; %>
        <% const chips = listing.chips || []; %>
        <% const venues = listing.venues || []; %>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <aside class="lg:col-span-3 space-y-8">
                <div class="bg-surface-container-low rounded-xl p-6 space-y-5">
                    <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant"><%= sidebar.title || 'Refine Results' %></h2>

                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-[0.08em] text-on-surface-variant" for="ls-input-explore-location"><%= sidebar.locationLabel || 'Location' %></label>
                        <%- include('components/location-search', {
                            id: 'explore-location',
                            placeholder: 'Search location...',
                            onSelect: 'handleExploreLocationSelect'
                        }) %>
                    </div>

                    <%- include('components/explore/filter-select', {
                        props: {
                            id: sidebar.priceSort?.id || 'priceSort',
                            name: sidebar.priceSort?.name || 'priceSort',
                            label: sidebar.priceLabel || 'Price',
                            icon: '$',
                            options: sidebar.priceSort?.options || []
                        }
                    }) %>
                </div>

                <div class="relative rounded-xl overflow-hidden aspect-[4/5] group cursor-pointer">
                    <img alt="Featured pitch" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://images.unsplash.com/photo-1431324155629-1a6deb1dec8d?q=80&w=1200&auto=format&fit=crop" />
                    <div class="absolute inset-0 bg-gradient-to-t from-emerald-950 via-transparent to-transparent opacity-80"></div>
                    <div class="absolute bottom-0 left-0 p-6">
                        <span class="inline-block px-2 py-1 bg-primary text-[10px] font-bold text-white uppercase rounded mb-2 tracking-widest">Promo</span>
                        <h3 class="text-white font-headline font-bold text-xl leading-tight">Elite Turf Night Sessions</h3>
                        <p class="text-emerald-100/80 text-xs mt-1">20% off for bookings after 10 PM</p>
                    </div>
                </div>
            </aside>

            <div class="lg:col-span-9 space-y-8">
                <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                    <div>
                        <h1 class="text-3xl font-extrabold font-headline text-on-surface tracking-tight"><%= listing.title || 'Available Pitches' %></h1>
                        <p class="text-on-surface-variant text-sm mt-1"><%= listing.subtitle || '' %></p>
                    </div>
                    <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-2">
                        <% chips.forEach((chip) => { %>
                            <%- include('components/explore/action-chip', { props: chip }) %>
                        <% }) %>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <% venues.forEach((venue) => { %>
                        <%- include('components/explore/venue-card', { props: { venue } }) %>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>


    <%- include('partials/footer.ejs') %>

        <script>
            function handleExploreLocationSelect(place, instanceId) {
                console.log('[Explore] Location selected:', place);
                // TODO: use place.description / place.placeId to filter pitches
            }

            // Also available as a DOM event:
            document.addEventListener('ls:select', function (e) {
                console.log('[Explore] ls:select event detail:', e.detail);
            });
        </script>