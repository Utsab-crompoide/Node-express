<%- include('partials/header.ejs') %>

    <main class="pt-24 pb-12 px-6 max-w-7xl mx-auto">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- ── Sidebar: Refine Results ─────────────────────────── -->
            <div class="lg:col-span-1 bg-surface-container-low p-6 rounded-xl">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="font-headline font-bold text-on-surface-variant">Refine Results</h2>
                </div>

                <!-- Location filter -->
                <div class="mb-5">
                    <span
                        class="block font-['Plus_Jakarta_Sans'] font-bold text-on-surface-variant text-xs text-[#3D4A40] mb-2 tracking-widest uppercase">Location</span>
                    <%- include('components/location-search', { id : 'explore-location' , placeholder
                        : 'Search location…' , onSelect : 'handleExploreLocationSelect' }) %>
                </div>
                <div class="relative">
                    <span
                        class="block font-['Plus_Jakarta_Sans'] font-bold text-on-surface-variant text-xs text-[#3D4A40] mb-2 tracking-widest uppercase">Price</span>
                    <span class="absolute inset-y-0 left-4 flex items-center text-[#6d7a6f] pointer-events-none">
                        $
                    </span>

                    <!-- Select -->
                    <select name="priceSort" class="text-[#3d4a40] pl-10 pr-3 py-2.5 border-none rounded-md w-full 
    shadow-[0_1px_4px_rgba(0,0,0,0.06),0_0_0_1px_rgba(0,0,0,0.07)] 
    appearance-none bg-white">

                        <option value="">Sort by price</option>
                        <option value="lowToHigh">Low to High</option>
                        <option value="highToLow">High to Low</option>
                    </select>
                </div>
            </div>

            <!-- ── Main: Available Pitches ────────────────────────── -->
            <div class="lg:col-span-2">
                <h3 class="text-3xl font-extrabold font-['Plus_Jakarta_Sans'] text-on-surface tracking-tight">Available
                    Pitches</h3>
                <span class="text-sm text-on-surface-variant text-[#3D4A40]">Found 20 arenas near you</span>
            </div>

            <div class="">
                <span>CCC</span>
            </div>

        </div>
    </main>


    <%- include('partials/footer.ejs') %>

        <script>
            /**
             * Called by the location-search component when a user selects a suggestion.
             * @param {Object} place  - { placeId, name, description, secondaryText, lat, lng }
             * @param {string} instanceId - the component's id prop
             */
            function handleExploreLocationSelect(place, instanceId) {
                console.log('[Explore] Location selected:', place);
                // TODO: use place.description / place.placeId to filter pitches
            }

            // Also available as a DOM event:
            document.addEventListener('ls:select', function (e) {
                console.log('[Explore] ls:select event detail:', e.detail);
            });
        </script>