<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>FutsalFlow - Home Dashboard</title>
    <!-- Font Imports -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <!-- Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "background": "#f6fafe",
                        "primary": "#006d40",
                        "error-container": "#ffdad6",
                        "on-tertiary-fixed": "#40000c",
                        "inverse-on-surface": "#edf1f5",
                        "surface-container-low": "#f0f4f8",
                        "surface-container-lowest": "#ffffff",
                        "secondary": "#515f74",
                        "tertiary-container": "#f97883",
                        "on-primary": "#ffffff",
                        "surface-container": "#eaeef2",
                        "surface-variant": "#dfe3e7",
                        "inverse-primary": "#5cde97",
                        "on-primary-fixed-variant": "#00522f",
                        "surface-dim": "#d6dade",
                        "tertiary": "#a53845",
                        "tertiary-fixed": "#ffdada",
                        "on-secondary": "#ffffff",
                        "primary-fixed-dim": "#5cde97",
                        "on-tertiary-container": "#6f0e21",
                        "error": "#ba1a1a",
                        "on-secondary-fixed-variant": "#3a485c",
                        "surface-container-high": "#e4e9ed",
                        "on-tertiary": "#ffffff",
                        "secondary-container": "#d5e3fd",
                        "on-error": "#ffffff",
                        "outline-variant": "#bccabd",
                        "on-background": "#171c1f",
                        "on-error-container": "#93000a",
                        "outline": "#6d7a6f",
                        "inverse-surface": "#2c3134",
                        "primary-container": "#2bb673",
                        "secondary-fixed-dim": "#b9c7e0",
                        "on-primary-container": "#004024",
                        "surface-tint": "#006d40",
                        "on-surface-variant": "#3d4a40",
                        "primary-fixed": "#7afbb1",
                        "surface-container-highest": "#dfe3e7",
                        "on-tertiary-fixed-variant": "#85202f",
                        "surface-bright": "#f6fafe",
                        "on-primary-fixed": "#002110",
                        "on-surface": "#171c1f",
                        "tertiary-fixed-dim": "#ffb3b6",
                        "on-secondary-container": "#57657b",
                        "surface": "#f6fafe",
                        "on-secondary-fixed": "#0d1c2f",
                        "secondary-fixed": "#d5e3fd"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="bg-background text-on-surface font-body antialiased">
<header class="fixed top-0 w-full z-50 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl shadow-sm">
    <div class="flex items-center justify-between px-6 py-3 max-w-7xl mx-auto">
        <!-- Brand Logo -->
        <div class="text-xl font-extrabold text-emerald-800 dark:text-emerald-400 font-headline tracking-tight">
            The Kinetic Turf
        </div>
        <!-- Navigation Links -->
        <nav class="hidden md:flex items-center gap-8">
            <a class="text-emerald-700 dark:text-emerald-400 border-b-2 border-emerald-600 pb-1 font-['Plus_Jakarta_Sans'] font-bold tracking-tight" href="/home">Home</a>
            <a class="text-slate-600 dark:text-slate-400 hover:text-emerald-600 transition-colors font-['Plus_Jakarta_Sans'] font-bold tracking-tight" href="/about">About</a>
            <a class="text-slate-600 dark:text-slate-400 hover:text-emerald-600 transition-colors font-['Plus_Jakarta_Sans'] font-bold tracking-tight" href="/account">My Account</a>
        </nav>
        <!-- Trailing Actions -->
        <div class="flex items-center gap-4">
            <% if(typeof user !== 'undefined' && user) { %>
                <span class="text-sm font-bold text-on-surface-variant hidden md:block">Welcome, <%= user.fullName %></span>
                <a href="/logout" class="text-sm font-bold text-emerald-600 hover:text-emerald-800">Log out</a>
                <button class="p-2 text-on-surface-variant hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors active:scale-95 duration-200">
                    <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
                </button>
                <div class="w-10 h-10 rounded-full overflow-hidden bg-surface-container border-2 border-primary-container/20">
                    <img alt="User profile avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCy7ZmtAzkzr81K6gJnNDrGGkA7ZlleBxtMjNVZ0sotH1XbA7lUNJB924zPqo5mfbCZ3INVx0mYEEKaAG0ceevVuUbSdMUb_qOid1sUNjNPXDsFWLY8R62C0el5g5z8TG2gBhrZ3BtwU0mJYPd4U42qD1-LzGAbEpT_uvVc1tT0_J0F7-QDkhM6JNvqr03fMavt6vq87Er-G1VvJkbKcPk5-xofqZoTZL0RASr4SQLx70Ft-QU5n6zcsKNG5mGvWKL6fbFhaBpPEdQ"/>
                </div>
            <% } else { %>
                <a href="/login" class="text-sm font-bold text-slate-600 hover:text-emerald-600">Log in</a>
                <a href="/signUp" class="text-sm font-bold bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary-container transition-colors">Sign up</a>
            <% } %>
        </div>
    </div>
</header>
<!-- Bottom Navigation for Mobile -->
<nav class="md:hidden fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-xl border-t border-slate-100 flex justify-around items-center py-3 z-50">
    <a href="/home" class="flex flex-col items-center text-primary">
        <span class="material-symbols-outlined" data-icon="home" style="font-variation-settings: 'FILL' 1;">home</span>
        <span class="text-[10px] font-bold mt-1">Home</span>
    </a>
    <a href="/explore" class="flex flex-col items-center text-slate-500">
        <span class="material-symbols-outlined" data-icon="search">search</span>
        <span class="text-[10px] font-bold mt-1">Explore</span>
    </a>
    <a href="/bookings" class="flex flex-col items-center text-slate-500">
        <span class="material-symbols-outlined" data-icon="calendar_month">calendar_month</span>
        <span class="text-[10px] font-bold mt-1">Bookings</span>
    </a>
    <a href="/account" class="flex flex-col items-center text-slate-500">
        <span class="material-symbols-outlined" data-icon="person">person</span>
        <span class="text-[10px] font-bold mt-1">Profile</span>
    </a>
</nav>