<main class="pt-24 pb-12 px-6 max-w-7xl mx-auto">
    <!-- Hero Section: Quick Actions & Welcome -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-12">
        <div class="lg:col-span-8 flex flex-col justify-center p-8 bg-gradient-to-br from-primary to-primary-container rounded-xl text-on-primary overflow-hidden relative">
            <!-- Abstract Design Elements -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-20 -mt-20 blur-3xl"></div>
            <h1 class="text-4xl font-headline font-extrabold tracking-tight mb-4">Hello, Champion!</h1>
            <p class="text-lg text-primary-fixed font-medium mb-8 max-w-md">The pitch is calling. Ready for your next legendary match at The Kinetic Turf?</p>
            
            <div class="flex flex-wrap gap-4">
                <button class="flex items-center gap-2 px-8 py-4 bg-surface-container-lowest text-primary font-headline font-bold rounded-xl shadow-lg hover:shadow-xl transition-all active:scale-95">
                    <span class="material-symbols-outlined" data-icon="stadium">stadium</span>
                    Book a Futsal
                </button>
                <button class="flex items-center gap-2 px-8 py-4 bg-primary-container border border-white/20 text-on-primary font-headline font-bold rounded-xl hover:bg-primary/80 transition-all">
                    <span class="material-symbols-outlined" data-icon="group">group</span>
                    Find a Team
                </button>
            </div>
        </div>

        <!-- Notifications / Reminders Sidebar Tonal Style -->
        <div class="lg:col-span-4 bg-surface-container-low p-6 rounded-xl">
            <div class="flex items-center justify-between mb-6">
                <h2 class="font-headline font-bold text-on-surface-variant">Live Reminders</h2>
                <span class="text-primary text-sm font-semibold cursor-pointer">Clear All</span>
            </div>
            <div class="space-y-4">
                <% liveReminders.forEach(reminder => { %>
                    <%- include('components/live_reminder', { reminder }) %>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Upcoming Bookings -->
    <section class="mb-12">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-headline font-bold tracking-tight">Upcoming Bookings</h2>
            <a class="text-primary font-semibold flex items-center gap-1 hover:gap-2 transition-all" href="#">
                View Schedule <span class="material-symbols-outlined text-sm" data-icon="arrow_forward">arrow_forward</span>
            </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% upcomingBookings.forEach(booking => { %>
                <%- include('components/booking_card', { booking }) %>
            <% }); %>

            <!-- Empty State / Add New -->
            <div class="border-2 border-dashed border-outline-variant rounded-xl flex flex-col items-center justify-center p-6 text-outline group hover:border-primary/50 transition-colors cursor-pointer">
                <div class="w-12 h-12 bg-surface-container rounded-full flex items-center justify-center mb-4 group-hover:bg-primary-container group-hover:text-on-primary transition-all">
                    <span class="material-symbols-outlined" data-icon="add">add</span>
                </div>
                <span class="font-headline font-bold">New Booking</span>
            </div>
        </div>
    </section>

    <!-- Recommended Grid -->
    <section class="mb-12">
        <h2 class="text-2xl font-headline font-bold tracking-tight mb-6">Recommended Futsals</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            <% recommendedFutsals.forEach(futsal => { %>
                <%- include('components/futsal_card', { futsal }) %>
            <% }); %>
        </div>
    </section>

    <!-- Recently Viewed -->
    <section>
        <h2 class="text-lg font-headline font-bold text-on-surface-variant mb-4">Recently Viewed</h2>
        <div class="flex gap-4 overflow-x-auto hide-scrollbar pb-4">
            <% recentlyViewed.forEach(view => { %>
                <%- include('components/recently_viewed_card', { view }) %>
            <% }); %>
        </div>
    </section>
</main>

<!-- FAB for quick action on mobile -->
<button class="md:hidden fixed bottom-20 right-6 w-14 h-14 bg-primary text-on-primary rounded-full shadow-2xl flex items-center justify-center z-50 active:scale-90 transition-transform">
    <span class="material-symbols-outlined" data-icon="add">add</span>
</button>

