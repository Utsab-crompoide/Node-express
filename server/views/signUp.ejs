<%- include('partials/header.ejs'); -%>

<main class="pt-32 pb-20 px-6 flex items-center justify-center min-h-[85vh]">
  <div class="bg-surface-container-lowest p-8 md:p-10 rounded-2xl shadow-sm w-full max-w-md border border-surface-variant">
    <div class="text-center mb-8">
      <h2 class="font-headline font-extrabold text-3xl text-on-surface tracking-tight mb-2">Create Account</h2>
      <p class="text-on-surface-variant text-sm font-medium">Join the Kinetic Turf community today.</p>
    </div>

    <form class="flex flex-col">
      <label for="fullName" class="text-sm font-bold text-on-surface mb-2">Full Name</label>
      <input type="text" name="fullName" class="w-full bg-surface-container-low text-on-surface outline-none border-2 border-transparent focus:border-primary rounded-xl p-4 transition-colors" placeholder="John Doe" required />
      <div class="fullName error text-error text-xs font-bold mt-1 mb-4 h-4"></div>

      <label for="email" class="text-sm font-bold text-on-surface mb-2">Email</label>
      <input type="email" name="email" class="w-full bg-surface-container-low text-on-surface outline-none border-2 border-transparent focus:border-primary rounded-xl p-4 transition-colors" placeholder="Enter your email" required />
      <div class="email error text-error text-xs font-bold mt-1 mb-4 h-4"></div>

      <label for="password" class="text-sm font-bold text-on-surface mb-2">Password</label>
      <input type="password" name="password" class="w-full bg-surface-container-low text-on-surface outline-none border-2 border-transparent focus:border-primary rounded-xl p-4 transition-colors" placeholder="Create a password" required />
      <div class="password error text-error text-xs font-bold mt-1 mb-6 h-4"></div>

      <button type="submit" class="w-full bg-primary text-on-primary font-headline font-bold rounded-xl py-4 shadow-lg hover:shadow-xl hover:translate-y-[-2px] hover:bg-primary-container transition-all active:scale-95 flex justify-center items-center gap-2">
        Sign Up <span class="material-symbols-outlined text-sm">person_add</span>
      </button>

      <p class="text-center text-sm text-on-surface-variant font-medium mt-6">
        Already have an account? <a href="/login" class="text-primary hover:text-primary-container font-bold">Log in</a>
      </p>

      <script>
        const form = document.querySelector('form')
        const emailError = document.querySelector('.email.error');
        const passwordError = document.querySelector('.password.error');
        const fullNameError = document.querySelector('.fullName.error');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            //reset the error
            emailError.textContent = ''
            passwordError.textContent = ''
            fullNameError.textContent = ''

            //get the values
            const email = form.email.value
            const password = form.password.value
            const fullName = form.fullName.value
            
            try {
                const res = await fetch('/user/createUser', {
                    method: 'POST',
                    body: JSON.stringify({email: email, password: password, fullName: fullName}),
                    headers: {'Content-Type': 'application/json'}
                })
                const data = await res.json()
                
                if(data.errors){
                    emailError.textContent = data.errors.email
                    passwordError.textContent = data.errors.password
                    fullNameError.textContent = data.errors.fullName
                } else {
                    location.assign('/home')
                }
            } catch(err){
                console.log(err)
            }
        })
      </script>
    </form>
  </div>
</main>

<%- include('partials/footer'); -%>